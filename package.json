{
  "name": "portfolio",
  "version": "2.19.5",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "analyze": "cross-env ANALYZE=true npm run build",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "type-check": "tsc --noEmit",
    "verify": "npm run type-check && npm run check",
    "cleanup": "pwsh scripts/cleanup.ps1",
    "cleanup:bash": "bash scripts/cleanup.sh",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:chromium": "playwright test --project=chromium",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "e2e:codegen": "playwright codegen http://localhost:3000",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "prepare": "husky",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "release:patch": "commit-and-tag-version --release-as patch"
  },
